import os
import platform
import subprocess
from datetime import datetime

# Lista de servidores ou IPs que você quer monitorar (ex: Google, DNS local, Gateway)
SERVERS = ["8.8.8.8", "1.1.1.1", "google.com"]

def ping_server(host):
    # Determina o parâmetro do comando ping com base no Sistema Operacional (Windows ou Linux)
    param = '-n' if platform.system().lower() == 'windows' else '-c'
    command = ['ping', param, '1', host]
    
    # Executa o comando e retorna True se o servidor responder
    return subprocess.call(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0

def run_monitor():
    print(f"--- Iniciando Monitoramento: {datetime.now().strftime('%d/%m/%Y %H:%M:%S')} ---")
    
    with open("status_report.txt", "a") as file:
        file.write(f"\nRelatório de {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}\n")
        
        for server in SERVERS:
            status = "ONLINE" if ping_server(server) else "OFFLINE"
            result = f"[SERVIÇO: {server}] -> STATUS: {status}"
            
            print(result)
            file.write(result + "\n")
    
    print("--- Monitoramento concluído. Log salvo em 'status_report.txt' ---")

if __name__ == "__main__":
    run_monitor()
